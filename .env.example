# SWAXS Platform — example environment file
# Copy to .env for LOCAL, NON-SECRET config only. .env is git-ignored.
#
# You normally DON'T need this file: the AI Assistant reads its token, endpoint,
# and model from ~/.claude/settings.json automatically (see SECURITY.md).
#
# DO NOT put the SLAC token in this file or anywhere in the repo.
# To override the settings.json values for a session, export them in your shell:
#   export ANTHROPIC_AUTH_TOKEN="$(security find-generic-password -s slac-anthropic -w)"
#
# Non-secret overrides you *may* set here if you want:
# ANTHROPIC_BASE_URL=https://ai-api.slac.stanford.edu
# ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-6

# Optional: operator/user recorded with each reduction (else OS login is used)
# SWAXS_USER_ID=
